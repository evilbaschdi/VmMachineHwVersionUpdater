<!-- ReSharper disable once Xaml.PathError -->
<windowing:FAAppWindow xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                       xmlns:viewModels="clr-namespace:VmMachineHwVersionUpdater.Avalonia.ViewModels"
                       xmlns:models="clr-namespace:VmMachineHwVersionUpdater.Core.Models;assembly=VmMachineHwVersionUpdater.Core"
                       xmlns:windowing="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
                       xmlns:evilBaschdi="clr-namespace:EvilBaschdi.Core.Avalonia.Controls;assembly=EvilBaschdi.Core.Avalonia"
                       xmlns:converters="clr-namespace:VmMachineHwVersionUpdater.Avalonia.Converters"
                       x:Class="VmMachineHwVersionUpdater.Avalonia.Views.MainWindow"
                       x:DataType="viewModels:MainWindowViewModel" mc:Ignorable="d"
                       d:DesignWidth="1600" d:DesignHeight="700" Width="1600" Height="700"
                       Title="VM Toolbox">

    <Window.Resources>
        <converters:MachineStateConverter x:Key="MachineStateConverter" />
    </Window.Resources>

    <Panel Name="RootPanel">

        <!-- ReSharper disable once Xaml.PathError -->
        <evilBaschdi:TitleBarControl Icon="/Assets/b.ico" Name="TitleBarControl" />

        <Panel Name="MainPanel" Margin="0,30,0,0">
            <Panel Name="ContentPanel" Margin="0,0,0,0">
                <Grid Margin="7" RowDefinitions="*,1,46">

                    <DataGrid Grid.Row="0" Name="MachineGrid" ItemsSource="{Binding DataGridCollectionViewMachines}" AutoGenerateColumns="False" ColumnWidth="*"
                              GridLinesVisibility="Horizontal" SelectionMode="Single" SelectedItem="{Binding Path=SelectedMachine}" ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Styles>
                            <Style Selector="DataGridCell.TipDisplayName" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding DisplayName}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipExtendedInformation" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding Annotation}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipMachineState" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding MachineState}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipPath" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding Path}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipDirectorySize" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding DirectorySize}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipGuestOs" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding GuestOsRaw}" x:DataType="models:Machine" />
                            </Style>
                            <Style Selector="DataGridCell.TipLogLastDate" x:DataType="models:Machine">
                                <Setter Property="ToolTip.Tip" Value="{Binding LogLastDateDiff}" x:DataType="models:Machine" />
                            </Style>
                        </DataGrid.Styles>
                        <DataGrid.Columns>
                            <!-- Display Name -->
                            <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" SortMemberPath="DisplayName" Width="*" FontSize="12" IsReadOnly="True"
                                                CellStyleClasses="TipDisplayName" x:DataType="models:Machine" />
                            <!-- ExtendedInformation -->
                            <DataGridTextColumn Header="🚩" Binding="{Binding ExtendedInformation}" SortMemberPath="ExtendedInformation" Width="60" FontSize="12" IsReadOnly="True"
                                                CellStyleClasses="TipExtendedInformation" x:DataType="models:Machine" />
                            <!-- Start -->
                            <DataGridTemplateColumn Header="Start" Width="70" IsReadOnly="False" CellStyleClasses="TipMachineState">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- ReSharper disable Xaml.PossibleNullReferenceException -->
                                        <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                                        <!-- ReSharper disable once Xaml.StyleClassNotFound -->
                                        <Button VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                Width="60" Classes="accent"
                                                Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).StartCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:FASymbolIcon Symbol="{Binding MachineState, Converter={StaticResource MachineStateConverter}}" FontSize="18" />
                                            </StackPanel>
                                        </Button>
                                        <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                                        <!-- ReSharper restore Xaml.PossibleNullReferenceException -->
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Path -->
                            <DataGridTextColumn Header="Path" Binding="{Binding ShortPath}" SortMemberPath="ShortPath" Width="*" FontSize="12" IsReadOnly="True"
                                                CellStyleClasses="TipPath" x:DataType="models:Machine" />
                            <!-- Directory Size (GB) -->
                            <DataGridTextColumn Header="Directory Size (GB)" Binding="{Binding DirectorySizeGb}" SortMemberPath="DirectorySizeGb" Width="150" FontSize="12"
                                                IsReadOnly="True"
                                                CellStyleClasses="TipDirectorySize" x:DataType="models:Machine" />
                            <!-- Guest OS -->
                            <DataGridTextColumn Header="Guest OS" Binding="{Binding GuestOs}" SortMemberPath="GuestOs" Width="200" FontSize="12" IsReadOnly="True"
                                                CellStyleClasses="TipGuestOs" x:DataType="models:Machine" />
                            <!-- Sync Time -->
                            <DataGridCheckBoxColumn Header="Sync Time" Binding="{Binding SyncTimeWithHost}" SortMemberPath="SyncTimeWithHost" Width="100" IsReadOnly="False"
                                                    x:DataType="models:Machine" />
                            <!-- Auto Update Tools -->
                            <DataGridCheckBoxColumn Header="Auto Update Tools" Binding="{Binding AutoUpdateTools}" SortMemberPath="AutoUpdateTools" Width="145" IsReadOnly="False"
                                                    x:DataType="models:Machine" />
                            <!-- Accelerate 3D Graphics -->
                            <DataGridCheckBoxColumn Header="Accelerate 3D Graphics" Binding="{Binding Accelerate3DGraphics}" SortMemberPath="Accelerate3DGraphics" Width="170"
                                                    IsReadOnly="False"
                                                    x:DataType="models:Machine" />
                            <!-- Memory -->
                            <DataGridTemplateColumn Header="Memory (GB)" SortMemberPath="MemSize" Width="120" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <TextBlock Text="{Binding MemSize}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="110" x:DataType="models:Machine" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <NumericUpDown Value="{Binding MemSize}" HorizontalAlignment="Stretch" Minimum="0" Maximum="120" x:DataType="models:Machine" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <!-- Version -->
                            <DataGridTemplateColumn Header="Version" SortMemberPath="HwVersion" Width="120" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <TextBlock Text="{Binding HwVersion}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="110" x:DataType="models:Machine" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <NumericUpDown Value="{Binding HwVersion}" HorizontalAlignment="Stretch" Minimum="0" Maximum="120" x:DataType="models:Machine" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <!-- Last Log Entry -->
                            <DataGridTextColumn Header="Last Log Entry" Binding="{Binding LogLastDate}" SortMemberPath="LogLastDate" Width="150" FontSize="12" IsReadOnly="True"
                                                CellStyleClasses="TipLogLastDate" x:DataType="models:Machine" />
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <!-- ReSharper disable Xaml.RedundantResource -->
                                <!-- Start -->
                                <MenuItem Header="Start machine..." Command="{Binding StartCommand}" />

                                <!-- Rename -->
                                <MenuItem Header="Rename..." Command="{Binding RenameCommand}" />

                                <!-- Add / Edit Annotation -->
                                <MenuItem Header="Add / Edit Annotation..." Command="{Binding AddEditAnnotationCommand}" />

                                <!-- Open with Code -->
                                <MenuItem Header="Open with Code..." Command="{Binding OpenWithCodeCommand}" />

                                <!-- Go to -->
                                <MenuItem Header="Go to path..." Command="{Binding GoToCommand}" />

                                <Separator />

                                <!-- Copy -->
                                <MenuItem Header="Copy machine..." Command="{Binding CopyCommand}" />

                                <!-- Archive -->
                                <MenuItem Header="Archive machine..." Command="{Binding ArchiveCommand}" />

                                <!-- Delete -->
                                <MenuItem Header="Delete machine..." Command="{Binding DeleteCommand}" />
                                <!-- ReSharper restore Xaml.RedundantResource -->
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <Separator Grid.Row="1" />

                    <controls:FACommandBar Grid.Row="2" Margin="7" HorizontalAlignment="Center">
                        <controls:FACommandBar.PrimaryCommands>
                            <!-- Search Filter -->
                            <controls:FACommandBarElementContainer>
                                <TextBox Width="250" HorizontalAlignment="Center" VerticalAlignment="Top" IsReadOnly="{Binding SearchFilterIsReadOnly}"
                                         Text="{Binding SearchFilterText,Mode=TwoWay}" PlaceholderText="enter search term" />
                            </controls:FACommandBarElementContainer>
                            <!-- Search Os -->
                            <controls:FACommandBarElementContainer>
                                <controls:FAComboBox Width="250" Name="SearchOs" HorizontalAlignment="Center" VerticalAlignment="Top" IsEnabled="{Binding SearchOsIsEnabled}"
                                                     ItemsSource="{Binding SearchOsItemCollection}" SelectedItem="{Binding SearchOsText}" IsEditable="True"
                                                     IsTextSearchEnabled="True" />
                            </controls:FACommandBarElementContainer>
                            <controls:FACommandBarSeparator />
                            <!-- Update all -->
                            <controls:FACommandBarElementContainer>
                                <Button VerticalAlignment="Top" HorizontalAlignment="Left" Command="{Binding UpdateAllCommand}" IsEnabled="{Binding UpdateAllIsEnabled}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding UpdateAllTextBlockText}" />
                                    </StackPanel>
                                </Button>
                            </controls:FACommandBarElementContainer>
                            <controls:FACommandBarElementContainer>
                                <NumericUpDown Width="120" Value="{Binding UpdateAllHwVersionValue}" HorizontalAlignment="Center" VerticalAlignment="Top" />
                            </controls:FACommandBarElementContainer>
                            <!-- Restart -->
                            <controls:FACommandBarSeparator />
                            <controls:FACommandBarElementContainer>
                                <Button VerticalAlignment="Top" HorizontalAlignment="Left" Command="{Binding ReloadCommand}" ToolTip.Tip="Restart">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:FASymbolIcon Symbol="Sync" FontSize="18" />
                                    </StackPanel>
                                </Button>
                            </controls:FACommandBarElementContainer>
                            <!-- About -->
                            <controls:FACommandBarSeparator />
                            <controls:FACommandBarElementContainer>
                                <Button VerticalAlignment="Top" HorizontalAlignment="Left" Command="{Binding AboutWindowCommand}" ToolTip.Tip="About">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:FASymbolIcon Symbol="More" FontSize="18" />
                                    </StackPanel>
                                </Button>
                            </controls:FACommandBarElementContainer>
                        </controls:FACommandBar.PrimaryCommands>
                    </controls:FACommandBar>

                </Grid>
            </Panel>
        </Panel>
    </Panel>

</windowing:FAAppWindow>